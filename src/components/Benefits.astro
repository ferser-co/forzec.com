---
import Icon from './Icon.astro';
import { benefits } from '../data/site';
---

<section id="tecnologia" class="relative py-20 sm:py-28 bg-[#0a0a0a]">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-[1fr_1.4fr] gap-12 lg:gap-16 items-center">
      <div class="reveal">
        <p class="mb-3 text-[10px] font-bold uppercase tracking-[0.3em] text-[var(--color-forzec)]">
          <span class="inline-block h-px w-8 bg-[var(--color-forzec)] align-middle mr-2"></span>
          Tecnología
        </p>
        <h2 class="text-4xl sm:text-5xl font-black tracking-cine leading-[0.95] text-white mb-5">
          TECNOLOGÍA QUE<br/>
          <span class="text-[var(--color-forzec)]">TRANSFORMA.</span>
        </h2>
        <p class="text-base sm:text-lg text-zinc-400 max-w-md leading-relaxed mb-8">
          Fórmula avanzada que entrega resultados profesionales en segundos.
        </p>
        <a href="#resultados" class="btn-ghost inline-flex items-center gap-2 rounded-md px-5 py-3 text-xs font-black uppercase tracking-[0.18em] text-white">
          <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-[var(--color-forzec)]">
            <Icon name="play" class="w-3 h-3 text-white" />
          </span>
          Conoce cómo funciona
        </a>
      </div>

      <div class="grid grid-cols-2 gap-px bg-white/5 reveal" style="transition-delay: 120ms;">
        {benefits.map((b, i) => (
          <article class="group flex flex-col items-start gap-3 bg-[#0a0a0a] p-7 sm:p-8 hover:bg-[#111] transition-colors">
            <span class="inline-flex h-12 w-12 items-center justify-center text-[var(--color-forzec)]">
              <Icon name={b.icon} class="w-8 h-8" strokeWidth={1.5} />
            </span>
            <h3 class="text-xl sm:text-2xl font-black tracking-tight text-white uppercase">
              {b.title}
            </h3>
            <p class="text-sm text-zinc-400 leading-relaxed">{b.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
