---
import Icon from './Icon.astro';
import Logo from './Logo.astro';

const year = new Date().getFullYear();
---

<footer class="relative bg-black border-t border-white/5">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid sm:grid-cols-2 lg:grid-cols-[2fr_1fr_1fr] gap-10">
      <div>
        <Logo size="lg" class="text-white" />
        <p class="mt-3 text-sm text-zinc-500 max-w-sm leading-relaxed">
          Soluciones técnicas de limpieza premium para cada superficie.
          Sin agua. Sin límites.
        </p>
        <p class="mt-5 text-[10px] uppercase tracking-[0.22em] text-zinc-500">
          Un producto de
          <a
            href="https://aseolab.co"
            target="_blank"
            rel="noopener"
            class="text-zinc-300 hover:text-white font-bold transition-colors ml-1"
          >ASEOLAB S.A.S.</a>
        </p>
      </div>

      <div>
        <h3 class="text-[10px] font-black uppercase tracking-[0.2em] text-zinc-400 mb-4">Enlaces</h3>
        <ul class="space-y-2.5 text-sm text-zinc-500">
          <li><a href="#aplicaciones" class="hover:text-white transition-colors">Aplicaciones</a></li>
          <li><a href="#resultados"   class="hover:text-white transition-colors">Resultados</a></li>
          <li><a href="#tecnologia"   class="hover:text-white transition-colors">Tecnología</a></li>
          <li><a href="#comprar"      class="hover:text-white transition-colors">Comprar</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-[10px] font-black uppercase tracking-[0.2em] text-zinc-400 mb-4">Contacto</h3>
        <ul class="space-y-2.5 text-sm text-zinc-500">
          <li class="inline-flex items-center gap-2">
            <Icon name="message-circle" class="w-3.5 h-3.5 text-[var(--color-forzec)]" />
            WhatsApp 24/7
          </li>
          <li class="inline-flex items-center gap-2">
            <Icon name="shopping-bag" class="w-3.5 h-3.5 text-[var(--color-forzec)]" />
            Disponible en Rappi
          </li>
          <li class="inline-flex items-center gap-2">
            <Icon name="truck" class="w-3.5 h-3.5 text-[var(--color-forzec)]" />
            Envíos a toda Colombia
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-6 border-t border-white/5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <p class="text-[11px] uppercase tracking-[0.18em] text-zinc-600">
        © {year}
        <a
          href="https://aseolab.co"
          target="_blank"
          rel="noopener"
          class="text-zinc-400 hover:text-white font-bold transition-colors mx-1"
        >ASEOLAB S.A.S.</a>
        Todos los derechos reservados.
      </p>
      <p class="text-[11px] uppercase tracking-[0.18em] text-zinc-600">
        Sitio desarrollado por
        <a
          href="https://ferser.co"
          target="_blank"
          rel="noopener"
          class="text-zinc-400 hover:text-white font-bold transition-colors ml-1"
        >Ferser</a>
      </p>
    </div>
  </div>
</footer>
