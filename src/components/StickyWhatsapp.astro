---
import Icon from './Icon.astro';
import { waUrl } from '../data/site';

const wa = waUrl();
---

<a
  href={wa}
  target="_blank"
  rel="noopener"
  aria-label="Hablar por WhatsApp"
  class="wa-sticky fixed bottom-5 right-5 z-50 inline-flex items-center justify-center h-14 w-14 rounded-full bg-[#25D366] text-white hover:brightness-110 transition-all"
>
  <Icon name="message-circle" class="w-6 h-6" />
</a>
